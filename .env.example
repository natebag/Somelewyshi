# ======================
# Miro Fish — Environment Variables
# Copy to .env and fill in your values
# ======================

# --- LLM ---
ANTHROPIC_API_KEY=sk-ant-...

# --- Polymarket ---
POLYMARKET_PRIVATE_KEY=0x...
POLYMARKET_FUNDER_ADDRESS=0x...

# --- MiroFish ---
ZEP_API_KEY=...

# --- Discord Alerts ---
DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...

# --- MoneyPrinterV2 (broadcast) ---
GEMINI_API_KEY=...
TWITTER_COOKIES_PATH=./secrets/twitter_cookies.json
YOUTUBE_COOKIES_PATH=./secrets/youtube_cookies.json
